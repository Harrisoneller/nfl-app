# ============================================================
# Statletics NFL — environment variables
# Copy to `.env` (root of repo) and fill in.
# ============================================================

# --- Core ---
APP_ENV=development                # development | production
# web = API only (Railway public). worker = scheduler + data jobs. Local dev: worker.
APP_ROLE=worker
# Boot warmups on worker: minimal (default) | none | full (dev only — high RAM)
BOOT_WARMUP_LEVEL=minimal
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-a-long-random-string

# --- Database ---
# Default assumes local Homebrew Postgres with current OS user
DATABASE_URL=postgresql+psycopg://localhost/nflapp

# --- Auth ---
# false: every request resolves to the seeded system@local user (single-tenant,
#        good for pure local dev). The login JWT is IGNORED in this mode.
# true:  real signup/login. The frontend's Bearer token is honored, anonymous
#        visitors can still browse public pages, and per-user features (bets,
#        widgets) become private to each account.
# Public/production posture is `true` so people can register and sign in.
#
# ⚠️ Trap: if you set ADMIN_EMAILS below but leave this false, NO ONE can reach
# admin routes — every request is system@local, which isn't in the allowlist,
# so even a successful admin login 403s. startup_doctor warns about this.
MULTI_USER_MODE=true
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080           # 7 days
RATE_LIMIT_AUTH=10/minute          # login attempts per IP
# Comma-separated emails granted admin-only routes (Sparky /admin/*, projection
# overrides, backfill, settle, backtest). With MULTI_USER_MODE=true, the logged-in
# email is matched against this list: allowlisted = admin, everyone else = a normal
# registered user with no admin privileges. Leave blank to fall back to the DB
# is_admin column instead.
ADMIN_EMAILS=harrisoneller@outlook.com
# NOTE: with real auth on, SECRET_KEY must be a stable random value shared by every
# service (web + worker) — it signs the JWTs. A placeholder or rotating key logs
# people out on each deploy.
# OAuth (not implemented — see docs/OAUTH.md)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=

# --- LLM provider (swap with one line) ---
LLM_PROVIDER=grok                  # grok | anthropic | openai
GROK_API_KEY=                      # https://x.ai
GROK_MODEL=grok-3
ANTHROPIC_API_KEY=                 # optional fallback
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=                    # optional fallback
OPENAI_MODEL=gpt-4o-mini

# --- Data sources ---
ESPN_BASE_URL=https://site.api.espn.com/apis/site/v2/sports/football/nfl
# https://the-odds-api.com — free tier 500 req/mo; put the key alone on this line (no inline comment)
ODDS_API_KEY=
ODDS_API_BASE=https://api.the-odds-api.com/v4

# --- Player props (per-event endpoint; billed per event × market-group) ---
# Rides the odds cron tick with its own budget guards: only events within
# PLAYER_PROPS_LOOKAHEAD_DAYS, max PLAYER_PROPS_MAX_EVENTS per run, min
# PLAYER_PROPS_MIN_REFRESH_HOURS between pulls. Off-season = zero spend.
PLAYER_PROPS_ENABLED=true
PLAYER_PROPS_MARKETS=player_pass_yds,player_pass_tds,player_rush_yds,player_rush_attempts,player_receptions,player_reception_yds,player_anytime_td
PLAYER_PROPS_MAX_EVENTS=16
PLAYER_PROPS_MIN_REFRESH_HOURS=12
PLAYER_PROPS_LOOKAHEAD_DAYS=7

# --- News / social feature flags ---
ENABLE_TWITTER=false               # flip when you have a paid X API key
TWITTER_BEARER_TOKEN=
RSS_FEEDS=https://www.espn.com/espn/rss/nfl/news,https://profootballtalk.nbcsports.com/feed/,https://www.cbssports.com/rss/headlines/nfl/

# --- Scheduler (worker only) ---
SCHEDULE_SCORES_SECONDS=30         # live scoreboard; disabled Mar–Aug
SCHEDULE_NEWS_SECONDS=300
SCHEDULE_ODDS_SECONDS=900          # deprecated; odds use ODDS_REFRESH_HOURS_UTC
ODDS_REFRESH_HOURS_UTC=1,13
DERIVE_CRON_HOURS_UTC=6,18         # materialize + elo + profiles + MC + awards (UTC)
H2H_CRON_HOURS_UTC=3               # H2H prewarm only — 03:30 UTC (nightly)

# --- Database pool / safety (per process) ---
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# Server-side query timeout (ms). Applied on the WEB role only (worker derive
# jobs run long and are exempt). 0 disables. Postgres only.
# DB_STATEMENT_TIMEOUT_MS=15000

# --- Rate limits (per client IP; enforced globally via SlowAPIMiddleware) ---
# RATE_LIMIT_DEFAULT=60/minute   # all routes (probes exempt)
# RATE_LIMIT_AI=20/hour
# RATE_LIMIT_AUTH=10/minute

# --- Cache (optional Redis for multiple web replicas) ---
# CACHE_BACKEND=memory
# CACHE_BACKEND=redis            # also makes rate-limit counters global across replicas
# REDIS_URL=redis://localhost:6379/0

# --- CORS (backend web service — required for browser calls from Vercel) ---
# Comma-separated frontend origins, no trailing slash. Example production:
# CORS_ORIGINS=https://statletics.io  (www apex is added automatically)
# cors_allow_vercel_regex=true allows any https://*.vercel.app preview URL
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_BASE=http://localhost:8000
