# ============================================================
# NFL App — environment variables
# Copy to `.env` (root of repo) and fill in.
# ============================================================

# --- Core ---
APP_ENV=development                # development | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-a-long-random-string

# --- Database ---
# Default assumes local Homebrew Postgres with current OS user
DATABASE_URL=postgresql+psycopg://localhost/nflapp

# --- Auth (multi-user is OFF by default; runs as hardcoded "me") ---
MULTI_USER_MODE=false
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080           # 7 days

# --- LLM provider (swap with one line) ---
LLM_PROVIDER=grok                  # grok | anthropic | openai
GROK_API_KEY=                      # https://x.ai
GROK_MODEL=grok-3
ANTHROPIC_API_KEY=                 # optional fallback
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=                    # optional fallback
OPENAI_MODEL=gpt-4o-mini

# --- Data sources ---
ESPN_BASE_URL=https://site.api.espn.com/apis/site/v2/sports/football/nfl
ODDS_API_KEY=                      # https://the-odds-api.com (free tier: 500/mo)
ODDS_API_BASE=https://api.the-odds-api.com/v4

# --- News / social feature flags ---
ENABLE_TWITTER=false               # flip when you have a paid X API key
TWITTER_BEARER_TOKEN=
RSS_FEEDS=https://www.espn.com/espn/rss/nfl/news,https://profootballtalk.nbcsports.com/feed/,https://www.cbssports.com/rss/headlines/nfl/

# --- Scheduler intervals (seconds) ---
SCHEDULE_SCORES_SECONDS=30
SCHEDULE_NEWS_SECONDS=300
SCHEDULE_ODDS_SECONDS=900

# --- Frontend ---
NEXT_PUBLIC_API_BASE=http://localhost:8000
