# Base URL of the FastAPI backend.
#
# EXPO_PUBLIC_* variables are inlined at build time and read first by
# src/lib/api.ts. If unset, the app falls back to app.json -> expo.extra.apiBase,
# then to http://localhost:8000.
#
# Copy this file to `.env` and set the value for how you're testing:
#
#   - Deployed backend (Railway):  https://<your-app>.up.railway.app
#   - iOS simulator + local API:   http://localhost:8000
#   - Physical iPhone + local API: http://<your-mac-LAN-ip>:8000  (e.g. http://192.168.1.42:8000)
#
# Note: the native app does not send a browser Origin header, so the backend's
# CORS_ORIGINS setting does not need to list the app — CORS only applies to the
# web frontend.
EXPO_PUBLIC_API_BASE=https://your-app.up.railway.app
